generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 String         @id
  code               String         @unique
  businessName       String
  ownerName          String
  plan               String
  subscriptionStatus String
  city               String?
  mobile             String?
  activeCustomers    Int            @default(0)
  staffCount         Int            @default(0)
  smsCredits         Int            @default(0)
  monthlyCollection  Float          @default(0)
  users              User[]
  customers          Customer[]
  packages           Package[]
  payments           Payment[]
  recharges          Recharge[]
  staffMembers       StaffMember[]
  expenses           Expense[]
  settings           TenantSetting?
  olts               Olt[]
  onts               Ont[]
  acsTasks           AcsTask[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model User {
  id           String   @id
  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  name         String
  email        String   @unique
  mobile       String?
  passwordHash String
  role         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Package {
  id           String     @id
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  name         String
  type         String
  price        Float
  validityDays Int        @default(30)
  customers    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Customer {
  id             String   @id
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  customerCode   String
  name           String
  mobile         String
  area           String?
  status         String   @default("active")
  packageId      String?
  packageName    String?
  dueAmount      Float    @default(0)
  dueDate        String?
  expiryDate     String?
  connectionType String   @default("both")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, customerCode])
}

model Payment {
  id            String   @id
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  customerId    String
  receiptNumber String   @unique
  customerName  String
  amountPaid    Float
  paymentMode   String
  paymentDate   String
  status        String
  createdAt     DateTime @default(now())
}

model Recharge {
  id            String   @id
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  customerId    String
  customerName  String
  mode          String
  status        String
  amount        Float
  oldExpiryDate String?
  newExpiryDate String?
  createdAt     DateTime @default(now())
}

model StaffMember {
  id        String   @id
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  mobile    String
  role      String
  status    String
  createdAt DateTime @default(now())
}

model Expense {
  id          String   @id
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  title       String
  category    String
  amount      Float
  expenseDate String
  createdAt   DateTime @default(now())
}

model TenantSetting {
  tenantId       String  @id
  tenant         Tenant  @relation(fields: [tenantId], references: [id])
  companyName    String?
  billingDay     Int     @default(1)
  lateFee        Float   @default(0)
  supportMobile  String?
  address        String?
  acsUsername    String?
  acsPassword    String?
  defaultAcsProfile String? @default("tr181")
  defaultWifiSsidPath String?
  defaultWifiPasswordPath String?
  defaultInformInterval Int? @default(300)
  autoApproveOnts Boolean @default(true)
  tr069TemplateName String?
}

model Olt {
  id             String   @id
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  name           String
  vendor         String
  model          String?
  ipAddress      String
  username       String?
  password       String?
  firmware       String?
  location       String?
  ponPorts       Int      @default(0)
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  onts           Ont[]

  @@unique([tenantId, ipAddress])
}

model Ont {
  id                     String   @id
  tenantId               String
  tenant                 Tenant   @relation(fields: [tenantId], references: [id])
  oltId                  String?
  olt                    Olt?     @relation(fields: [oltId], references: [id])
  customerId             String?
  serialNumber           String
  macAddress             String?
  vendor                 String?
  model                  String?
  ponPort                String?
  onuIndex               String?
  lineProfile            String?
  serviceProfile         String?
  tr069Enabled           Boolean  @default(false)
  acsDeviceId            String?  @unique
  acsProfile             String   @default("tr181")
  connectionRequestUrl   String?
  connectionRequestUser  String?
  connectionRequestPass  String?
  wifiSsidPath           String?
  wifiPasswordPath       String?
  wifiSsid               String?
  wifiPassword           String?
  wanMode                String?
  pppoeUsername          String?
  pppoePassword          String?
  status                 String   @default("offline")
  discoveryStatus        String   @default("approved")
  informCount            Int      @default(0)
  lastFaultCode          String?
  lastFaultMessage       String?
  lastInformAt           DateTime?
  lastProvisionedAt      DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  acsTasks               AcsTask[]

  @@unique([tenantId, serialNumber])
}

model AcsTask {
  id              String   @id
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  ontId           String?
  ont             Ont?     @relation(fields: [ontId], references: [id])
  taskType        String
  commandKey      String?
  status          String   @default("queued")
  retryCount      Int      @default(0)
  nextRetryAt     DateTime?
  faultCode       String?
  requestedBy     String?
  payload         String?
  resultMessage   String?
  executedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AcsEvent {
  id            String   @id
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  ontId         String?
  eventType     String
  serialNumber  String?
  payload       String?
  status        String?
  details       String?
  createdAt     DateTime @default(now())
}
